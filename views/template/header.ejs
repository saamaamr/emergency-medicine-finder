<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Emergency Medicine Finder - Find medicines near you in Bangladesh" />
  <meta name="author" content="Emergency Medicine Finder" />
  <link rel="shortcut icon" href="images/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="images/favicon.svg" type="image/svg+xml">
  <title>EMF - Emergency Medicine Finder</title>

  <!-- Google Fonts: Figtree + Noto Sans (Healthcare Design System) -->
  <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700;800&family=Noto+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Remix Icon & EOS Icons -->
  <link href="https://cdn.jsdelivr.net/npm/remixicon@2.5.0/fonts/remixicon.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/eos-icons/dist/css/eos-icons.css" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <!-- Custom Styles (Design System) -->
  <link href="css/style.css" rel="stylesheet" />

  <!-- Browser Key Generation for Session Management -->
  <script>
    (function() {
      const BROWSER_KEY_NAME = 'emf_browser_key';
      function getOrCreateBrowserKey() {
        let key = localStorage.getItem(BROWSER_KEY_NAME);
        if (!key) {
          if (window.crypto && window.crypto.randomUUID) {
            key = crypto.randomUUID();
          } else {
            key = Date.now().toString(36) + Math.random().toString(36).substr(2) + Math.random().toString(36).substr(2);
          }
          localStorage.setItem(BROWSER_KEY_NAME, key);
        }
        return key;
      }
      window.emfBrowserKey = getOrCreateBrowserKey();
    })();
  </script>
</head>
