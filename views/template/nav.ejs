<div class="hero_area">
  <div class="hero_bg_box">
    <img src="images/hero-bg.jpg" alt="" />
  </div>
  <header class="header_section">
    <div class="container-fluid">
      <nav class="navbar navbar-expand-lg custom_nav-container">
        <a class="navbar-brand" href="/home">
          <img width="130" src="images/logo.svg" alt="EMF - Emergency Medicine Finder" />
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
          data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false"
          aria-label="Toggle navigation">
          <i class="ri-menu-line"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item <%= typeof activeNav !== 'undefined' && activeNav === 'home' ? 'active' : '' %>">
              <a class="nav-link" href="/home">Home</a>
            </li>
            <li class="nav-item <%= typeof activeNav !== 'undefined' && activeNav === 'about' ? 'active' : '' %>">
              <a class="nav-link" href="/about">About</a>
            </li>
            <% if(typeof uId !== 'undefined' && uId) { %>
              <li class="nav-item">
                <a class="nav-link" href="/profile">
                  <i class="ri-user-3-line"></i> <%= typeof userData !== 'undefined' && userData && userData[0] ? userData[0].first_name : '' %>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/req">My Requests</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/logout">Logout</a>
              </li>
            <% } else { %>
              <li class="nav-item">
                <a class="nav-link" href="/login">User Login</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/shopkeeperlogin">Shopkeeper Login</a>
              </li>
            <% } %>
          </ul>
          <form class="d-flex" role="search" onsubmit="return false;">
            <div class="input-group" style="border-radius: 24px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
              <span class="input-group-text" style="background: white; border: 1.5px solid #15803D; border-right: none; padding: 0 0 0 12px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#15803D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              </span>
              <input class="form-control" id="searchmedi" type="search" placeholder="Search Medicine..." aria-label="Search Medicine" style="border: 1.5px solid #15803D; border-left: none; padding: 8px 12px 8px 8px; font-size: 0.9rem; background: white;">
            </div>
          </form>
        </div>
      </nav>
    </div>
  </header>
</div>
