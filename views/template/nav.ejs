<link href="/css/variables.css" rel="stylesheet" />
<link href="/css/layout.css" rel="stylesheet" />

<!-- Modern Fixed Navbar (paymentform.io style - Pure CSS) -->
<input type="checkbox" id="nav-toggle" class="nav-toggle-check">
<nav class="emf-nav">
  <div class="emf-container">
    <!-- Logo -->
    <a class="emf-logo" href="/home">
      <img src="images/logo.svg" alt="Emergency Medicine Finder">
    </a>
    
    <!-- Mobile Toggle (Checkbox Hack) -->
    <label for="nav-toggle" class="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </label>
    
    <!-- Nav Content -->
    <div class="nav-menu">
      <!-- Nav Links -->
      <ul class="nav-links">
        <li class="nav-item <%= typeof activeNav !== 'undefined' && activeNav === 'home' ? 'active' : '' %>">
          <a class="nav-link" href="/home">Home</a>
        </li>
        <li class="nav-item <%= typeof activeNav !== 'undefined' && activeNav === 'about' ? 'active' : '' %>">
          <a class="nav-link" href="/about">About</a>
        </li>
        
        <!-- Services Mega Dropdown -->
        <li class="nav-item dropdown-wrapper">
          <a href="#" class="nav-link dropdown-trigger">
            Services
            <i class="ri-arrow-down-s-line"></i>
          </a>
          <div class="mega-dropdown">
            <div class="mega-dropdown-content">
              <div class="mega-dropdown-col">
                <h6 class="dropdown-title">For Patients</h6>
                <a class="dropdown-link" href="/service">
                  <i class="ri-capsule-line"></i>
                  <div class="dropdown-link-text">
                    <span class="link-title">Search Medicines</span>
                    <span class="link-desc">Find medicines near you</span>
                  </div>
                </a>
                <a class="dropdown-link" href="/contact">
                  <i class="ri-chat-3-line"></i>
                  <div class="dropdown-link-text">
                    <span class="link-title">Contact Us</span>
                    <span class="link-desc">Get support</span>
                  </div>
                </a>
                <a class="dropdown-link" href="/offer">
                  <i class="ri-gift-line"></i>
                  <div class="dropdown-link-text">
                    <span class="link-title">Offers</span>
                    <span class="link-desc">Special promotions</span>
                  </div>
                </a>
              </div>
              <div class="mega-dropdown-col">
                <h6 class="dropdown-title">For Pharmacies</h6>
                <a class="dropdown-link" href="/shopkeeperlogin">
                  <i class="ri-store-line"></i>
                  <div class="dropdown-link-text">
                    <span class="link-title">Shop Login</span>
                    <span class="link-desc">Manage your pharmacy</span>
                  </div>
                </a>
                <a class="dropdown-link" href="/shopkeepersignup">
                  <i class="ri-add-circle-line"></i>
                  <div class="dropdown-link-text">
                    <span class="link-title">Register Shop</span>
                    <span class="link-desc">Join our network</span>
                  </div>
                </a>
                <a class="dropdown-link" href="/service">
                  <i class="ri-medicine-bottle-line"></i>
                  <div class="dropdown-link-text">
                    <span class="link-title">Medicine Catalog</span>
                    <span class="link-desc">Browse all medicines</span>
                  </div>
                </a>
              </div>
            </div>
          </div>
        </li>
      </ul>
      
      <!-- Right Side: CTAs or User Menu + Search + Theme Toggle -->
      <div class="nav-actions">
        <% if (typeof uId !== 'undefined' && uId) { %>
          <!-- Logged In User Menu -->
          <div class="user-menu dropdown-wrapper">
            <button class="user-menu-trigger">
              <% if (typeof userData !== 'undefined' && userData && userData[0] && userData[0].propic) { %>
                <img src="<%= userData[0].propic %>" class="user-avatar" alt="Profile">
              <% } else { %>
                <img src="/images/profile.png" class="user-avatar" alt="Profile">
              <% } %>
              <span class="user-name hide-tablet">
                <%= typeof userData !== 'undefined' && userData && userData[0] ? userData[0].first_name : 'Account' %>
              </span>
              <i class="ri-arrow-down-s-line"></i>
            </button>
            <div class="user-dropdown">
              <a class="dropdown-link" href="/profile">
                <i class="ri-user-line"></i>
                <div class="dropdown-link-text">
                  <span class="link-title">My Profile</span>
                </div>
              </a>
              <a class="dropdown-link" href="/req">
                <i class="ri-file-list-line"></i>
                <div class="dropdown-link-text">
                  <span class="link-title">My Requests</span>
                </div>
              </a>
              <a class="dropdown-link" href="/booked">
                <i class="ri-shopping-bag-3-line"></i>
                <div class="dropdown-link-text">
                  <span class="link-title">My Bookings</span>
                </div>
              </a>
              <div class="dropdown-divider"></div>
              <a class="dropdown-link text-danger" href="/logout">
                <i class="ri-logout-box-line"></i>
                <div class="dropdown-link-text">
                  <span class="link-title">Logout</span>
                </div>
              </a>
            </div>
          </div>
        <% } else { %>
          <!-- Not Logged In -->
          <div class="auth-buttons">
            <div class="dropdown-wrapper hide-tablet pharmacy-dropdown">
              <button class="btn-pharmacy-modern dropdown-trigger">
                <i class="ri-store-2-line"></i>
                For Pharmacies
                <i class="ri-arrow-down-s-line dropdown-arrow"></i>
              </button>
              <div class="pharmacy-dropdown-menu">
                <a class="dropdown-link" href="/shopkeeperlogin">
                  <i class="ri-login-circle-line"></i>
                  <span>Shop Login</span>
                </a>
                <a class="dropdown-link" href="/shopkeepersignup">
                  <i class="ri-add-circle-line"></i>
                  <span>Register Shop</span>
                </a>
                <div class="dropdown-divider"></div>
                <a class="dropdown-link" href="#">
                  <i class="ri-dashboard-line"></i>
                  <span>Dashboard Demo</span>
                </a>
              </div>
            </div>
            <a href="/login" class="btn-modern btn-modern-ghost">Sign In</a>
            <a href="/signup" class="btn-modern btn-modern-primary">Sign Up</a>
          </div>
        <% } %>
        
        <!-- Glassmorphism Search Bar -->
        <div class="nav-search-glass hide-mobile">
          <form action="/home" method="GET" class="search-form-glass">
            <div class="search-wrapper-glass">
              <i class="ri-search-line search-icon-glass"></i>
              <input type="text" name="mname" class="search-input-glass" 
                     placeholder="Search medicine..." autocomplete="off">
              <button type="submit" class="search-btn-glass">
                <i class="ri-arrow-right-line"></i>
              </button>
            </div>
          </form>
        </div>
        
        <!-- Theme Toggle -->
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
          <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- Scroll Effect Script + Body Padding -->
<script>
  (function() {
    const nav = document.querySelector('.emf-nav');
    if (!nav) return;
    
    // Add body padding for fixed navbar
    document.body.style.paddingTop = '70px';
    
    window.addEventListener('scroll', function() {
      if (window.scrollY > 50) {
        nav.classList.add('navbar-shrunk');
        document.body.style.paddingTop = '60px';
      } else {
        nav.classList.remove('navbar-shrunk');
        document.body.style.paddingTop = '70px';
      }
    });
  })();
</script>

<!-- Theme Toggle Script -->
<script>
  (function() {
    const themeToggle = document.getElementById('themeToggle');
    if (!themeToggle) return;
    
    const savedTheme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = savedTheme === 'dark' || (!savedTheme && prefersDark);
    
    if (isDark) {
      document.documentElement.classList.add('dark');
    }
    
    themeToggle.addEventListener('click', function() {
      document.documentElement.classList.toggle('dark');
      const isDarkNow = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDarkNow ? 'dark' : 'light');
    });
  })();
</script>