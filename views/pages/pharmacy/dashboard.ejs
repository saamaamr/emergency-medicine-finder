<%- include ('../../template/aheader') %>

<section class="main">
  <div class="sidebar">
    <div class="sidebar--profile mb-4 pb-3 border-bottom">
      <div class="text-center">
        <img src="<%= shopkeeperData[0].propic || '/images/default-shop.png' %>" class="rounded-circle mb-2" width="60" height="60">
        <h6 class="mb-0"><%= shopkeeperData[0].shopname %></h6>
        <small class="text-muted"><%= shopkeeperData[0].email %></small>
      </div>
    </div>
    <ul class="sidebar--items">
      <li><a href="/shopkeeperdesh"><span class="icon icon-1"><i class="ri-layout-grid-line"></i></span><span class="sidebar--item">Dashboard</span></a></li>
      <li><a href="/pharmacy/dashboard" id="active--link"><span class="icon icon-2"><i class="ri-store-2-line"></i></span><span class="sidebar--item">Pharmacy</span></a></li>
      <li><a href="/pharmacy/suppliers"><span class="icon icon-3"><i class="ri-truck-line"></i></span><span class="sidebar--item">Suppliers</span></a></li>
      <li><a href="/pharmacy/purchases"><span class="icon icon-4"><i class="ri-shopping-cart-line"></i></span><span class="sidebar--item">Purchases</span></a></li>
      <li><a href="/pharmacy/sales"><span class="icon icon-5"><i class="ri-handbag-line"></i></span><span class="sidebar--item">Sales</span></a></li>
      <li><a href="/pharmacy/expenses"><span class="icon icon-6"><i class="ri-bill-line"></i></span><span class="sidebar--item">Expenses</span></a></li>
      <li><a href="/pharmacy/reports"><span class="icon icon-7"><i class="ri-bar-chart-line"></i></span><span class="sidebar--item">Reports</span></a></li>
      <li><a href="/pharmacy/export"><span class="icon icon-8"><i class="ri-upload-cloud-line"></i></span><span class="sidebar--item">Export Data</span></a></li>
      <li><a href="/servicereq"><span class="icon icon-9"><i class="ri-git-repository-line"></i></span><span class="sidebar--item">Med Requests</span></a></li>
      <li><a href="/shopprofile"><span class="icon icon-10"><i class="ri-user-settings-line"></i></span><span class="sidebar--item">My Profile</span></a></li>
    </ul>
    <ul class="sidebar--bottom-items">
      <li><a href="/shopkeeperlogout"><span class="icon icon-10"><i class="ri-logout-box-r-line"></i></span><span class="sidebar--item">Logout</span></a></li>
    </ul>
  </div>

  <div class="main--content">
    <h4 class="mb-4"><i class="ri-store-2-line me-2"></i>Pharmacy Dashboard</h4>

    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h6 class="text-muted mb-2">Today's Sales</h6>
            <h3 class="text-success mb-0">৳<%= parseFloat(summary.today_sales).toFixed(2) %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h6 class="text-muted mb-2">Today's Profit</h6>
            <h3 class="text-primary mb-0">৳<%= parseFloat(summary.today_profit).toFixed(2) %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h6 class="text-muted mb-2">Today's Expenses</h6>
            <h3 class="text-danger mb-0">৳<%= parseFloat(summary.today_expenses).toFixed(2) %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h6 class="text-muted mb-2">Low Stock Items</h6>
            <h3 class="text-warning mb-0"><%= summary.low_stock_count %></h3>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h6 class="text-muted mb-2">Total Sales</h6>
            <h5 class="text-success mb-0">৳<%= parseFloat(summary.total_sales).toFixed(2) %></h5>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h6 class="text-muted mb-2">Total Profit</h6>
            <h5 class="text-primary mb-0">৳<%= parseFloat(summary.total_profit).toFixed(2) %></h5>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h6 class="text-muted mb-2">Purchase Due</h6>
            <h5 class="text-danger mb-0">৳<%= parseFloat(summary.total_purchase_due).toFixed(2) %></h5>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h6 class="text-muted mb-2">Suppliers</h6>
            <h5 class="mb-0"><%= summary.total_suppliers %></h5>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white border-bottom p-3">
            <h6 class="mb-0"><i class="ri-handbag-line me-1"></i>Recent Sales</h6>
          </div>
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
              <thead><tr><th>Invoice</th><th>Customer</th><th>Amount</th><th>Profit</th></tr></thead>
              <tbody>
                <% if (recentSales.length === 0) { %>
                  <tr><td colspan="4" class="text-center text-muted py-3">No sales yet</td></tr>
                <% } %>
                <% recentSales.forEach(s => { %>
                  <tr>
                    <td><a href="/pharmacy/sales/view/<%= s.sale_id %>"><%= s.invoice_no %></a></td>
                    <td><%= s.customer_name || 'Walk-in' %></td>
                    <td>৳<%= parseFloat(s.total_amount).toFixed(2) %></td>
                    <td class="text-success">৳<%= parseFloat(s.profit_amount).toFixed(2) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white border-bottom p-3">
            <h6 class="mb-0"><i class="ri-shopping-cart-line me-1"></i>Recent Purchases</h6>
          </div>
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
              <thead><tr><th>Invoice</th><th>Supplier</th><th>Amount</th><th>Status</th></tr></thead>
              <tbody>
                <% if (recentPurchases.length === 0) { %>
                  <tr><td colspan="4" class="text-center text-muted py-3">No purchases yet</td></tr>
                <% } %>
                <% recentPurchases.forEach(p => { %>
                  <tr>
                    <td><a href="/pharmacy/purchases/view/<%= p.purchase_id %>"><%= p.invoice_no %></a></td>
                    <td><%= p.supplier_name || 'N/A' %></td>
                    <td>৳<%= parseFloat(p.total_amount).toFixed(2) %></td>
                    <td><span class="badge <%= p.payment_status === 'paid' ? 'bg-success' : p.payment_status === 'partial' ? 'bg-warning' : 'bg-danger' %>"><%= p.payment_status %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include ('../../template/alfooter') %>
