<%- include ('../../template/aheader') %>

<section class="main">
  <div class="sidebar">
    <div class="sidebar--profile mb-4 pb-3 border-bottom">
      <div class="text-center">
        <img src="<%= shopkeeperData[0].propic || '/images/default-shop.png' %>" class="rounded-circle mb-2" width="60" height="60">
        <h6 class="mb-0"><%= shopkeeperData[0].shopname %></h6>
        <small class="text-muted"><%= shopkeeperData[0].email %></small>
      </div>
    </div>
    <ul class="sidebar--items">
      <li><a href="/shopkeeperdesh"><span class="icon icon-1"><i class="ri-layout-grid-line"></i></span><span class="sidebar--item">Dashboard</span></a></li>
      <li><a href="/pharmacy/dashboard"><span class="icon icon-2"><i class="ri-store-2-line"></i></span><span class="sidebar--item">Pharmacy</span></a></li>
      <li><a href="/pharmacy/suppliers"><span class="icon icon-3"><i class="ri-truck-line"></i></span><span class="sidebar--item">Suppliers</span></a></li>
      <li><a href="/pharmacy/purchases"><span class="icon icon-4"><i class="ri-shopping-cart-line"></i></span><span class="sidebar--item">Purchases</span></a></li>
      <li><a href="/pharmacy/sales"><span class="icon icon-5"><i class="ri-handbag-line"></i></span><span class="sidebar--item">Sales</span></a></li>
      <li><a href="/pharmacy/expenses"><span class="icon icon-6"><i class="ri-bill-line"></i></span><span class="sidebar--item">Expenses</span></a></li>
      <li><a href="/pharmacy/reports"><span class="icon icon-7"><i class="ri-bar-chart-line"></i></span><span class="sidebar--item">Reports</span></a></li>
      <li><a href="/pharmacy/export" id="active--link"><span class="icon icon-8"><i class="ri-upload-cloud-line"></i></span><span class="sidebar--item">Export Data</span></a></li>
      <li><a href="/servicereq"><span class="icon icon-9"><i class="ri-git-repository-line"></i></span><span class="sidebar--item">Med Requests</span></a></li>
      <li><a href="/shopprofile"><span class="icon icon-10"><i class="ri-user-settings-line"></i></span><span class="sidebar--item">My Profile</span></a></li>
    </ul>
    <ul class="sidebar--bottom-items">
      <li><a href="/shopkeeperlogout"><span class="icon icon-11"><i class="ri-logout-box-r-line"></i></span><span class="sidebar--item">Logout</span></a></li>
    </ul>
  </div>

  <div class="main--content">
    <% if (messages.error === 'true') { %>
      <div class="alert alert-danger alert-dismissible fade show"><i class="ri-error-warning-line me-2"></i>Export failed. Please try again.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <h4 class="mb-3"><i class="ri-upload-cloud-line me-2"></i>Export My Shop Data</h4>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-4">
        <h6 class="mb-3"><i class="ri-information-line me-1"></i>Download your shop data for offline use</h6>
        <p class="text-muted small mb-3">Exports include your suppliers, purchases, sales, expenses, and inventory. Admin full database backups are available separately.</p>

        <div class="d-flex gap-3 flex-wrap">
          <a href="/pharmacy/export/download/json" class="btn btn-primary">
            <i class="ri-file-code-line me-1"></i>Download All as JSON
          </a>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom p-3">
        <h6 class="mb-0"><i class="ri-file-excel-2-line me-1"></i>Download Individual CSV Files</h6>
      </div>
      <div class="card-body p-4">
        <div class="row g-3">
          <div class="col-md-3">
            <a href="/pharmacy/export/download/csv/suppliers" class="btn btn-outline-success w-100 py-3">
              <i class="ri-truck-line fs-4 d-block mb-1"></i>
              <small>Suppliers</small>
            </a>
          </div>
          <div class="col-md-3">
            <a href="/pharmacy/export/download/csv/purchases" class="btn btn-outline-success w-100 py-3">
              <i class="ri-shopping-cart-line fs-4 d-block mb-1"></i>
              <small>Purchases</small>
            </a>
          </div>
          <div class="col-md-3">
            <a href="/pharmacy/export/download/csv/purchase-items" class="btn btn-outline-success w-100 py-3">
              <i class="ri-list-check fs-4 d-block mb-1"></i>
              <small>Purchase Items</small>
            </a>
          </div>
          <div class="col-md-3">
            <a href="/pharmacy/export/download/csv/sales" class="btn btn-outline-success w-100 py-3">
              <i class="ri-handbag-line fs-4 d-block mb-1"></i>
              <small>Sales</small>
            </a>
          </div>
          <div class="col-md-3">
            <a href="/pharmacy/export/download/csv/sale-items" class="btn btn-outline-success w-100 py-3">
              <i class="ri-list-check fs-4 d-block mb-1"></i>
              <small>Sale Items</small>
            </a>
          </div>
          <div class="col-md-3">
            <a href="/pharmacy/export/download/csv/expenses" class="btn btn-outline-success w-100 py-3">
              <i class="ri-bill-line fs-4 d-block mb-1"></i>
              <small>Expenses</small>
            </a>
          </div>
          <div class="col-md-3">
            <a href="/pharmacy/export/download/csv/inventory" class="btn btn-outline-success w-100 py-3">
              <i class="ri-medicine-bottle-line fs-4 d-block mb-1"></i>
              <small>Inventory</small>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include ('../../template/alfooter') %>
