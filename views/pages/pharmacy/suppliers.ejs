<%- include ('../../template/aheader') %>

<section class="main">
  <div class="sidebar">
    <div class="sidebar--profile mb-4 pb-3 border-bottom">
      <div class="text-center">
        <img src="<%= shopkeeperData[0].propic || '/images/default-shop.png' %>" class="rounded-circle mb-2" width="60" height="60">
        <h6 class="mb-0"><%= shopkeeperData[0].shopname %></h6>
        <small class="text-muted"><%= shopkeeperData[0].email %></small>
      </div>
    </div>
    <ul class="sidebar--items">
      <li><a href="/shopkeeperdesh"><span class="icon icon-1"><i class="ri-layout-grid-line"></i></span><span class="sidebar--item">Dashboard</span></a></li>
      <li><a href="/pharmacy/dashboard"><span class="icon icon-2"><i class="ri-store-2-line"></i></span><span class="sidebar--item">Pharmacy</span></a></li>
      <li><a href="/pharmacy/suppliers" id="active--link"><span class="icon icon-3"><i class="ri-truck-line"></i></span><span class="sidebar--item">Suppliers</span></a></li>
      <li><a href="/pharmacy/purchases"><span class="icon icon-4"><i class="ri-shopping-cart-line"></i></span><span class="sidebar--item">Purchases</span></a></li>
      <li><a href="/pharmacy/sales"><span class="icon icon-5"><i class="ri-handbag-line"></i></span><span class="sidebar--item">Sales</span></a></li>
      <li><a href="/pharmacy/expenses"><span class="icon icon-6"><i class="ri-bill-line"></i></span><span class="sidebar--item">Expenses</span></a></li>
      <li><a href="/pharmacy/reports"><span class="icon icon-7"><i class="ri-bar-chart-line"></i></span><span class="sidebar--item">Reports</span></a></li>
      <li><a href="/servicereq"><span class="icon icon-8"><i class="ri-git-repository-line"></i></span><span class="sidebar--item">Med Requests</span></a></li>
      <li><a href="/shopprofile"><span class="icon icon-9"><i class="ri-user-settings-line"></i></span><span class="sidebar--item">My Profile</span></a></li>
    </ul>
    <ul class="sidebar--bottom-items">
      <li><a href="/shopkeeperlogout"><span class="icon icon-10"><i class="ri-logout-box-r-line"></i></span><span class="sidebar--item">Logout</span></a></li>
    </ul>
  </div>

  <div class="main--content">
    <% if (messages.added === 'true') { %>
      <div class="alert alert-success alert-dismissible fade show"><i class="ri-check-circle-line me-2"></i>Supplier added!<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (messages.updated === 'true') { %>
      <div class="alert alert-success alert-dismissible fade show"><i class="ri-check-circle-line me-2"></i>Supplier updated!<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (messages.deleted === 'true') { %>
      <div class="alert alert-success alert-dismissible fade show"><i class="ri-check-circle-line me-2"></i>Supplier deleted!<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (messages.error === 'true') { %>
      <div class="alert alert-danger alert-dismissible fade show"><i class="ri-error-warning-line me-2"></i>Something went wrong.<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="mb-0"><i class="ri-truck-line me-2"></i>Suppliers</h4>
      <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addSupplierModal"><i class="ri-add-line me-1"></i>Add Supplier</button>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead>
            <tr><th>Name</th><th>Company</th><th>Email</th><th>Phone</th><th>City</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% if (suppliers.length === 0) { %>
              <tr><td colspan="6" class="text-center text-muted py-4">No suppliers added yet</td></tr>
            <% } %>
            <% suppliers.forEach(s => { %>
              <tr>
                <td class="fw-500"><%= s.name %></td>
                <td><%= s.company || '-' %></td>
                <td><%= s.email || '-' %></td>
                <td><%= s.phone || '-' %></td>
                <td><%= s.city || '-' %></td>
                <td>
                  <button class="btn btn-sm btn-outline-primary" onclick='editSupplier(<%= JSON.stringify(s) %>)'><i class="ri-edit-line"></i></button>
                  <a href="/pharmacy/suppliers/delete/<%= s.supplier_id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this supplier?')"><i class="ri-delete-bin-line"></i></a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<div class="modal fade" id="addSupplierModal" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title"><i class="ri-add-line me-2"></i>Add Supplier</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form action="/pharmacy/suppliers/add" method="POST">
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label">Name *</label><input type="text" class="form-control" name="name" required></div>
          <div class="col-md-6"><label class="form-label">Company</label><input type="text" class="form-control" name="company"></div>
          <div class="col-md-6"><label class="form-label">Email</label><input type="email" class="form-control" name="email"></div>
          <div class="col-md-6"><label class="form-label">Phone</label><input type="text" class="form-control" name="phone"></div>
          <div class="col-md-6"><label class="form-label">City</label><input type="text" class="form-control" name="city"></div>
          <div class="col-md-12"><label class="form-label">Address</label><textarea class="form-control" name="address" rows="2"></textarea></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Supplier</button>
      </div>
    </form>
  </div></div>
</div>

<div class="modal fade" id="editSupplierModal" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title"><i class="ri-edit-line me-2"></i>Edit Supplier</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="POST" id="editSupplierForm">
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label">Name *</label><input type="text" class="form-control" name="name" id="edit_name" required></div>
          <div class="col-md-6"><label class="form-label">Company</label><input type="text" class="form-control" name="company" id="edit_company"></div>
          <div class="col-md-6"><label class="form-label">Email</label><input type="email" class="form-control" name="email" id="edit_email"></div>
          <div class="col-md-6"><label class="form-label">Phone</label><input type="text" class="form-control" name="phone" id="edit_phone"></div>
          <div class="col-md-6"><label class="form-label">City</label><input type="text" class="form-control" name="city" id="edit_city"></div>
          <div class="col-md-12"><label class="form-label">Address</label><textarea class="form-control" name="address" id="edit_address" rows="2"></textarea></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Update Supplier</button>
      </div>
    </form>
  </div></div>
</div>

<script>
function editSupplier(s) {
  document.getElementById('edit_name').value = s.name || '';
  document.getElementById('edit_company').value = s.company || '';
  document.getElementById('edit_email').value = s.email || '';
  document.getElementById('edit_phone').value = s.phone || '';
  document.getElementById('edit_city').value = s.city || '';
  document.getElementById('edit_address').value = s.address || '';
  document.getElementById('editSupplierForm').action = '/pharmacy/suppliers/update/' + s.supplier_id;
  new bootstrap.Modal(document.getElementById('editSupplierModal')).show();
}
</script>

<%- include ('../../template/alfooter') %>
