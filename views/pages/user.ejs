<%- include ('../template/aheader') %>

<section class="main">
  <div class="sidebar">
    <ul class="sidebar--items">
      <li><a href="/admin">
        <span class="icon icon-1"><i class="ri-layout-grid-line"></i></span>
        <span class="sidebar--item">Dashboard</span>
      </a></li>
      <li><a href="/service">
        <span class="icon icon-2"><i class="ri-git-repository-line"></i></span>
        <span class="sidebar--item">Medicine</span>
      </a></li>
      <li><a href="/admin/inventory">
        <span class="icon icon-3"><i class="ri-store-2-line"></i></span>
        <span class="sidebar--item">Inventory</span>
      </a></li>
      <li><a href="/admin/transfers">
        <span class="icon icon-4"><i class="ri-exchange-line"></i></span>
        <span class="sidebar--item">Transfers</span>
      </a></li>
      <li><a href="/user" id="active--link">
        <span class="icon icon-5"><i class="ri-user-line"></i></span>
        <span class="sidebar--item">User</span>
      </a></li>
      <li><a href="/shopkeeper">
        <span class="icon icon-6"><i class="ri-user-2-line"></i></span>
        <span class="sidebar--item sidebar-item-nowrap">Shopkeeper</span>
      </a></li>
    </ul>
    <ul class="sidebar--bottom-items">
      <li><a href="/adminlogout">
        <span class="icon icon-8"><i class="ri-logout-box-r-line"></i></span>
        <span class="sidebar--item">Logout</span>
      </a></li>
    </ul>
  </div>

  <div class="main--content">
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="p-3 border-bottom">
          <h5 class="section--title mb-0"><i class="ri-user-line me-1"></i>User List</h5>
        </div>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>Name</th>
                <th>Gender</th>
                <th>Email</th>
                <th>Mobile</th>
                <th>Address</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% allUser.forEach(user => { %>
                <tr>
                  <td><strong><%= user.first_name %> <%= user.last_name %></strong></td>
                  <td><span class="badge bg-light text-dark"><%= user.gender %></span></td>
                  <td class="text-muted small"><%= user.email %></td>
                  <td><%= user.phone %></td>
                  <td class="text-muted small">
                    <%= user.house %>, Road: <%= user.road %><br>
                    <%= user.upazila %>, <%= user.zila %>
                  </td>
                  <td>
                    <% if(user.status == 0) { %>
                      <span class="badge bg-warning">Pending</span>
                    <% } else if(user.status == 1) { %>
                      <span class="badge bg-success">Active</span>
                    <% } else { %>
                      <span class="badge bg-danger">Hold</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include ('../template/alfooter') %>
