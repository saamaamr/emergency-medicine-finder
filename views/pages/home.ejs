<%- include ('../template/header') %>
<link href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>
<link href="/css/map-style.css" rel="stylesheet" />
<%- include ('../template/nav') %>

<style>
  :root {
    --color-primary: #0284C7;
    --color-primary-dark: #0369A1;
    --color-primary-light: #38BDF8;
    --color-secondary: #0EA5E9;
    --color-cta: #059669;
    --color-cta-dark: #047857;
    --color-background: #ECFEFF;
    --color-text: #164E63;
    --color-text-muted: #0E7490;
    --color-surface: #FFFFFF;
    --color-border: #E2E8F0;
    --color-card: #FFFFFF;
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
    --focus-ring: 0 0 0 3px rgba(8, 145, 178, 0.4);
  }

  /* Dark Mode */
  .dark {
    --color-background: #0F172A;
    --color-text: #E0F2FE;
    --color-text-muted: #94A3B8;
    --color-surface: #1E293B;
    --color-border: #334155;
    --color-card: #1E293B;
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.2);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.3), 0 2px 4px -2px rgb(0 0 0 / 0.2);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.4), 0 4px 6px -4px rgb(0 0 0 / 0.3);
    --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.5), 0 8px 10px -6px rgb(0 0 0 / 0.3);
  }

  * {
    transition-property: color, background-color, border-color, box-shadow, transform, opacity;
    transition-timing-function: ease-out;
    transition-duration: 200ms;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }

  body {
    font-family: 'Noto Sans', sans-serif;
    color: var(--color-text);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Figtree', sans-serif;
  }

  /* Focus states for accessibility */
  a:focus-visible, button:focus-visible, input:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  /* Hero Section */
  .hero-section {
    background: linear-gradient(135deg, #ECFEFF 0%, #CFFAFE 50%, #A5F3FC 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle at 20% 80%, rgba(2, 132, 199, 0.08) 0%, transparent 50%),
                  radial-gradient(circle at 80% 20%, rgba(14, 165, 233, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-badge {
    background: linear-gradient(135deg, var(--color-primary), var(--color-cta));
    color: white;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    display: inline-block;
    animation: fadeInUp 0.6s ease-out;
  }

  .hero-title {
    color: #0F172A;
    font-weight: 800;
    line-height: 1.1;
    animation: fadeInUp 0.6s ease-out 0.1s backwards;
  }

  .hero-title span {
    background: linear-gradient(135deg, var(--color-primary), var(--color-cta));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    line-height: 1.7;
    animation: fadeInUp 0.6s ease-out 0.2s backwards;
  }

  .hero-cta {
    gap: 1rem;
    animation: fadeInUp 0.6s ease-out 0.3s backwards;
  }

  .btn-primary-emf {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    border: none;
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    border-radius: 0.75rem;
    cursor: pointer;
  }

  .btn-primary-emf:hover {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    color: white;
  }

  .btn-secondary-emf {
    background: white;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    border-radius: 0.75rem;
    cursor: pointer;
  }

  .btn-secondary-emf:hover {
    background: var(--color-background);
    transform: translateY(-2px);
    color: var(--color-primary);
  }

  /* Stats Strip */
  .stats-section {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    padding: 1.5rem 0;
  }

  .stat-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    border-radius: 0.75rem;
    padding: 1rem;
    transition: transform 0.2s ease-out;
  }

  .stat-card:hover {
    transform: translateY(-4px);
  }

  .stat-value {
    color: white;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
  }

  .stat-label {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

  /* Search Section */
  .search-section {
    background: var(--color-background);
    padding: 3rem 0;
  }

  .search-title {
    color: var(--color-text);
    font-weight: 700;
    font-family: 'Figtree', sans-serif;
  }

  .search-subtitle {
    color: var(--color-text-muted);
  }

  /* Search Input Group */
  .search-container {
    max-width: 640px;
    margin: 0 auto;
  }

  .search-input-group {
    background: var(--color-surface);
    border-radius: 1rem;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color 0.2s ease-out, box-shadow 0.2s ease-out;
  }

  .search-input-group:focus-within {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-xl), var(--focus-ring);
  }

  .search-input-group .input-group-text {
    background: linear-gradient(135deg, var(--color-primary), var(--color-cta));
    border: none;
    padding: 0 1.25rem;
  }

  .search-input-group input {
    border: none;
    padding: 1rem 1.25rem;
    font-size: 1rem;
  }

  .search-input-group input:focus {
    outline: none;
    box-shadow: none;
  }

  .search-btn {
    background: linear-gradient(135deg, var(--color-primary), var(--color-cta));
    color: white;
    border: none;
    padding: 1rem 1.5rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }

  .search-btn:hover {
    background: linear-gradient(135deg, var(--color-cta), var(--color-primary));
    transform: scale(1.02);
  }

  .search-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  /* Map Container */
  .map-container {
    height: 520px;
    border-radius: 1rem;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    border: 1px solid #E2E8F0;
    z-index: 1;
    position: relative;
    background: #f0f0f0;
  }

  #shopmap {
    height: 100%;
    width: 100%;
    z-index: 1;
  }

  .maplibregl-map {
    height: 100%;
    width: 100%;
  }

  .maplibregl-popup-content {
    font-family: 'Figtree', sans-serif;
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    padding: 0;
    overflow: hidden;
    min-width: 280px;
    border: none;
  }

  .maplibregl-popup-close-button {
    font-size: 20px;
    padding: 6px 10px;
    color: #64748B;
    background: #F1F5F9;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .maplibregl-popup-close-button:hover {
    background: #E2E8F0;
    color: #0284C7;
  }

  .maplibregl-ctrl-group {
    border-radius: 8px !important;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1) !important;
  }

  .maplibregl-ctrl-attrib {
    background: rgba(255,255,255,0.7) !important;
    font-size: 10px;
  }

  .maplibregl-ctrl-attrib a {
    color: #6b7280;
  }

  /* Results Sidebar */
  .results-sidebar {
    background: white;
    border-radius: 1rem;
    box-shadow: var(--shadow-lg);
    border: 1px solid #E2E8F0;
    height: 520px;
    overflow-y: auto;
  }

  .results-header {
    background: linear-gradient(135deg, #E0F2FE, #F0F9FF);
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    border-radius: 1rem 1rem 0 0;
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-surface);
  }

  .results-header h6 {
    color: var(--color-text);
    font-weight: 700;
    font-family: 'Figtree', sans-serif;
  }

  .result-count {
    background: var(--color-cta);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  /* Result Card */
  .result-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem;
    margin-bottom: 0.75rem;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }

  .result-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
    transform: translateX(4px);
  }

  .result-card.nearest {
    border-color: var(--accent, #F59E0B);
    background: var(--warning-light, #FEF3C7);
  }

  .result-card.nearest:hover {
    background: var(--warning-light, #FEF3C7);
  }

  .pharmacy-name {
    color: #0F172A;
    font-weight: 700;
    font-family: 'Figtree', sans-serif;
  }

  .nearest-badge {
    background: linear-gradient(135deg, #F59E0B, #D97706);
    color: white;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 9999px;
  }

  .medicine-name {
    color: #0284C7;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .medicine-price {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0284C7;
  }

  .stock-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
  }

  .stock-badge.in-stock {
    background: #D1FAE5;
    color: #059669;
  }

  .stock-badge.low-stock {
    background: #FEF3C7;
    color: #92400E;
  }

  .stock-badge.out-of-stock {
    background: #FEE2E2;
    color: #991B1B;
  }

  .distance-badge {
    background: #E0F2FE;
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
  }

  /* Empty States */
  .empty-state, .no-results-state {
    text-align: center;
    padding: 3rem 1rem;
    color: #94A3B8;
  }

  .empty-state svg, .no-results-state svg {
    color: #CBD5E1;
    margin-bottom: 1rem;
  }

  /* How It Works */
  .how-it-works {
    background: white;
    padding: 4rem 0;
  }

  .how-title {
    color: #0F172A;
    font-weight: 700;
    font-family: 'Figtree', sans-serif;
    margin-bottom: 3rem;
  }

  .step-card {
    background: linear-gradient(135deg, #E0F2FE, #F0F9FF);
    border-radius: 1rem;
    padding: 2rem;
    text-align: center;
    height: 100%;
    transition: all 0.3s ease-out;
    border: 2px solid transparent;
  }

  .step-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-cta);
  }

  .step-icon {
    width: 4rem;
    height: 4rem;
    background: linear-gradient(135deg, var(--color-primary), var(--color-cta));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    color: white;
  }

  .step-title {
    color: #0F172A;
    font-weight: 700;
    font-family: 'Figtree', sans-serif;
    margin-bottom: 0.5rem;
  }

  .step-description {
    color: #64748B;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Available Medicines */
  .medicines-section {
    background: #F8FAFC;
    padding: 4rem 0;
  }

  .medicines-title {
    color: #0F172A;
    font-weight: 700;
    font-family: 'Figtree', sans-serif;
  }

  .medicines-subtitle {
    color: #64748B;
  }

  .medicine-card {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid #E2E8F0;
    height: 100%;
    transition: all 0.3s ease-out;
  }

  .medicine-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }

  .medicine-icon {
    width: 3rem;
    height: 3rem;
    background: linear-gradient(135deg, #E0F2FE, #F0F9FF);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-cta);
    margin-bottom: 1rem;
  }

  .medicine-name {
    color: #0F172A;
    font-weight: 700;
    font-family: 'Figtree', sans-serif;
    margin-bottom: 0.25rem;
  }

  .medicine-details {
    color: #059669;
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .medicine-company {
    color: #94A3B8;
    font-size: 0.8rem;
  }

  .view-all-btn {
    background: white;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    border-radius: 0.75rem;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s ease-out;
  }

  .view-all-btn:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* Loading Spinner */
  .loading-spinner {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }

    .stat-value {
      font-size: 1.5rem;
    }

    .map-container, .results-sidebar {
      height: 400px;
      border-radius: 0.75rem;
    }

    .result-card {
      padding: 0.75rem;
    }

    .step-card {
      padding: 1.5rem;
    margin-bottom: 1rem;
    }
  }
</style>

<!-- Hero -->
<section class="hero-section py-5">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-6">
        <span class="hero-badge mb-3">Emergency Service</span>
        <h1 class="hero-title display-5 fw-bold mb-3">Find Medicines <span>Near You</span></h1>
        <p class="hero-description lead mb-4">Emergency Medicine Finder connects you with local pharmacies for fast access to essential medicines. Search, locate, and order medicines in minutes.</p>
        <div class="hero-cta d-flex flex-wrap">
          <a href="/service" class="btn btn-primary-emf btn-lg">Browse Medicines</a>
          <a href="/contact" class="btn btn-secondary-emf btn-lg">Contact Us</a>
        </div>
      </div>
      <div class="col-lg-6 text-center position-relative">
        <img src="images/hero-img.svg" alt="Emergency Medicine Finder" class="img-fluid" style="max-height: 380px; filter: drop-shadow(0 8px 24px rgba(21,128,61,0.12));">
      </div>
    </div>
  </div>
</section>

<!-- Stats Strip -->
<section class="stats-section">
  <div class="container">
    <div class="row text-center g-3">
      <div class="col-4 col-md-3 col-lg">
        <div class="stat-card">
          <div class="stat-value">500+</div>
          <div class="stat-label">Medicines</div>
        </div>
      </div>
      <div class="col-4 col-md-3 col-lg">
        <div class="stat-card">
          <div class="stat-value">100+</div>
          <div class="stat-label">Pharmacies</div>
        </div>
      </div>
      <div class="col-4 col-md-3 col-lg">
        <div class="stat-card">
          <div class="stat-value">50+</div>
          <div class="stat-label">Cities</div>
        </div>
      </div>
      <div class="col-4 col-md-3 col-lg mt-2 mt-md-0">
        <div class="stat-card">
          <div class="stat-value">10K+</div>
          <div class="stat-label">Orders</div>
        </div>
      </div>
      <div class="col-4 col-md-3 col-lg mt-2 mt-md-0">
        <div class="stat-card">
          <div class="stat-value">4.8★</div>
          <div class="stat-label">Rating</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Search + Map Section -->
<section class="search-section">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="search-title">Search <span style="color: var(--color-primary);">Medicines</span> Near You</h2>
      <p class="search-subtitle">Type a medicine name to instantly find it at nearby pharmacies</p>
    </div>

    <!-- Search Bar -->
    <div class="row justify-content-center mb-4">
      <div class="col-md-8 col-lg-6">
        <div class="search-container">
          <div class="search-input-group input-group input-group-lg">
            <span class="input-group-text">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </span>
            <input class="form-control" id="searchmedi-page" type="search" placeholder="Search Medicine by name..." aria-label="Search Medicine" autocomplete="off">
            <button class="search-btn" type="button" id="search-btn" aria-label="Search medicines">
              <span id="search-btn-text">Search</span>
            </button>
          </div>
          <div id="search-suggestions" class="mt-1" style="display: none;"></div>
        </div>
      </div>
    </div>

    <!-- Map + Results Layout -->
    <div class="row g-4">
      <div class="col-lg-8">
        <div id="shopmap" class="map-container" style="min-height: 520px;"></div>
      </div>
      <div class="col-lg-4">
        <div class="results-sidebar">
          <div class="results-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-cta)" style="display:inline;vertical-align:-3px;margin-right:4px;"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg> Pharmacies Found</h6>
            <span class="result-count" id="result-count">0</span>
          </div>
          <div id="results-list" class="p-3">
            <div class="empty-state" id="empty-state">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <p class="mt-3 mb-0" style="color: #64748B;">Type a medicine name above<br>to see nearby pharmacies</p>
            </div>
            <div id="no-results-state" style="display: none;" class="no-results-state">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M16 16s-1.5-2-4-2-4 2-4 2"></path>
                <line x1="9" y1="9" x2="9.01" y2="9"></line>
                <line x1="15" y1="9" x2="15.01" y2="9"></line>
              </svg>
              <p class="mt-3 mb-0 fw-bold" style="color: #0F172A;">No nearby pharmacies have this medicine</p>
              <p class="small mb-0" style="color: #94A3B8;">Try searching with a different medicine name</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How it Works -->
<section class="how-it-works">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="how-title">How It <span style="color: var(--color-primary);">Works</span></h2>
    </div>
    <div class="row g-4 text-center">
      <div class="col-md-4">
        <div class="step-card">
          <div class="step-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </div>
          <h5 class="step-title">Search Medicine</h5>
          <p class="step-description">Enter the medicine name and find all nearby pharmacies instantly on the map</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="step-card">
          <div class="step-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <h5 class="step-title">Locate Pharmacy</h5>
          <p class="step-description">See all shops with medicine on the map with distance and pricing</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="step-card">
          <div class="step-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
          </div>
          <h5 class="step-title">Place Order</h5>
          <p class="step-description">Upload prescription and request medicines for pickup or home delivery</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Available Medicines -->
<section class="medicines-section">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="medicines-title">Available <span style="color: var(--color-primary);">Medicines</span></h2>
      <p class="medicines-subtitle">Browse our catalog of medicines available at nearby pharmacies</p>
    </div>
    <div class="row g-4" id="data">
      <% if(typeof allService !== 'undefined') { %>
        <% allService.slice(0, 6).forEach(function(medi) { %>
          <div class="col-lg-4 col-md-6">
            <div class="medicine-card">
              <div class="medicine-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10.5 4.5v10.5M6.5 10.5h8"></path>
                  <path d="M18 20a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2h12z"></path>
                </svg>
              </div>
              <h5 class="medicine-name"><%= medi.name %></h5>
              <p class="medicine-details"><%= medi.generic %> | <%= medi.strength %></p>
              <p class="medicine-company"><%= medi.company %></p>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
    <div class="text-center mt-4">
      <a href="/service" class="view-all-btn">View All Medicines</a>
    </div>
  </div>
</section>

<%- include ('../template/footer') %>

