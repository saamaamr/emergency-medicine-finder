<%- include ('../template/header') %>
<%/**
 * Emergency Medicine Finder - Home Page
 * 
 * MIT License
 * Copyright (c) 2026 Abdullah Al Mamun
 * 
 * A web application that helps users find emergency medicines
 * at nearby pharmacies in Bangladesh.
 */%>
<link href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>
<link href="/css/variables.css" rel="stylesheet" />
<link href="/css/layout.css" rel="stylesheet" />
<link href="/css/home.css" rel="stylesheet" />
<link href="/css/map-style.css" rel="stylesheet" />
<%- include ('../template/nav') %>

<!-- Hero -->
<section class="hero-section py-5">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-6">
        <span class="hero-badge mb-3">Emergency Service</span>
        <h1 class="hero-title display-5 fw-bold mb-3">Find Medicines <span>Near You</span></h1>
        <p class="hero-description lead mb-4">Emergency Medicine Finder connects you with local pharmacies for fast access to essential medicines. Search, locate, and order medicines in minutes.</p>
        <div class="hero-cta d-flex flex-wrap">
          <a href="/service" class="btn btn-primary-emf btn-lg">Browse Medicines</a>
          <a href="/contact" class="btn btn-secondary-emf btn-lg">Contact Us</a>
        </div>
      </div>
      <div class="col-lg-6 text-center position-relative">
        <img src="images/hero-img.svg" alt="Emergency Medicine Finder" class="img-fluid hero-img">
      </div>
    </div>
  </div>
</section>

<!-- Stats Strip -->
<section class="stats-section">
  <div class="container">
    <div class="row text-center g-3">
      <div class="col-4 col-md-3 col-lg">
        <div class="stat-card">
          <div class="stat-value">500+</div>
          <div class="stat-label">Medicines</div>
        </div>
      </div>
      <div class="col-4 col-md-3 col-lg">
        <div class="stat-card">
          <div class="stat-value">100+</div>
          <div class="stat-label">Pharmacies</div>
        </div>
      </div>
      <div class="col-4 col-md-3 col-lg">
        <div class="stat-card">
          <div class="stat-value">50+</div>
          <div class="stat-label">Cities</div>
        </div>
      </div>
      <div class="col-4 col-md-3 col-lg mt-2 mt-md-0">
        <div class="stat-card">
          <div class="stat-value">10K+</div>
          <div class="stat-label">Orders</div>
        </div>
      </div>
      <div class="col-4 col-md-3 col-lg mt-2 mt-md-0">
        <div class="stat-card">
          <div class="stat-value">4.8★</div>
          <div class="stat-label">Rating</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Search + Map Section -->
<section class="search-section">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="search-title">Search <span class="text-primary">Medicines</span> Near You</h2>
      <p class="search-subtitle">Type a medicine name to instantly find it at nearby pharmacies</p>
    </div>

    <!-- Search Bar -->
    <div class="row justify-content-center mb-4">
      <div class="col-md-8 col-lg-6">
        <div class="search-modern">
          <div class="search-modern-wrapper">
            <div class="search-modern-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </div>
            <input class="search-modern-input" id="searchmedi-page" type="search" 
                   placeholder="Search medicine instantly (Napa, Ace, Seclo...)" 
                   aria-label="Search Medicine" autocomplete="off">
            <button class="search-modern-btn" type="button" id="search-btn" aria-label="Search medicines">
              <span class="btn-text">Find Now</span>
              <span class="loading-content">
                <span class="spinner"></span>
                <span class="loading-text">Searching...</span>
              </span>
            </button>
          </div>
          <div id="search-feedback" class="search-feedback"></div>
          <div id="search-suggestions" class="search-suggestions-container"></div>
        </div>
      </div>
    </div>

    <!-- Map + Results Layout -->
    <div class="row g-4">
      <div class="col-lg-8 position-relative">
        <div id="shopmap" class="map-container map-container-inline"></div>
        <!-- Location Floating Controls (outside map, inside col-lg-8) -->
        <div class="location-floating-controls">
          <div id="location-status" class="location-status status-default">
            <span class="location-icon">⚠️</span>
            <span class="location-text">Location not detected</span>
          </div>
          <div class="location-btn-group">
            <button id="btn-my-location" class="location-btn" title="Use My Location">
              <i class="ri-crosshair-line"></i>
            </button>
            <select id="city-selector" class="city-selector">
              <option value="">Select City</option>
              <option value="dhaka">Dhaka</option>
              <option value="chattogram">Chattogram</option>
              <option value="sylhet">Sylhet</option>
              <option value="khulna">Khulna</option>
              <option value="rangpur">Rangpur</option>
              <option value="barisal">Barisal</option>
              <option value="mymensingh">Mymensingh</option>
              <option value="rajshahi">Rajshahi</option>
            </select>
          </div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="results-sidebar">
          <div class="results-header">
            <h6>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Pharmacies Found
            </h6>
            <span class="result-count" id="result-count">0</span>
          </div>
          <div id="results-list">
            <div class="empty-state" id="empty-state">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <p>Type a medicine name above<br/>to see nearby pharmacies</p>
            </div>
            <div id="no-results-state" class="no-results-state no-results-state-hidden">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
              <p>No nearby pharmacy currently has this medicine</p>
              <p class="text-muted">Try searching with a different medicine name</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How it Works -->
<section class="how-it-works">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="how-title">How It <span class="text-primary">Works</span></h2>
    </div>
    <div class="row g-4 text-center">
      <div class="col-md-4">
        <div class="step-card">
          <div class="step-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </div>
          <h5 class="step-title">Search Medicine</h5>
          <p class="step-description">Enter the medicine name and find all nearby pharmacies instantly on the map</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="step-card">
          <div class="step-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <h5 class="step-title">Locate Pharmacy</h5>
          <p class="step-description">See all shops with medicine on the map with distance and pricing</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="step-card">
          <div class="step-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
          </div>
          <h5 class="step-title">Place Order</h5>
          <p class="step-description">Upload prescription and request medicines for pickup or home delivery</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Available Medicines -->
<section class="medicines-section">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="medicines-title">Available <span class="text-primary">Medicines</span></h2>
      <p class="medicines-subtitle">Browse our catalog of medicines available at nearby pharmacies</p>
    </div>
    <div class="row g-4" id="data">
      <% if(typeof allService !== 'undefined') { %>
        <% allService.slice(0, 6).forEach(function(medi) { %>
          <div class="col-lg-4 col-md-6">
            <div class="medicine-card">
              <div class="medicine-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10.5 4.5v10.5M6.5 10.5h8"></path>
                  <path d="M18 20a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2h12z"></path>
                </svg>
              </div>
              <h5 class="medicine-name"><%= medi.name %></h5>
              <p class="medicine-details"><%= medi.generic %> | <%= medi.strength %></p>
              <p class="medicine-company"><%= medi.company %></p>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
    <div class="text-center mt-4">
      <a href="/service" class="view-all-btn">View All Medicines</a>
    </div>
  </div>
</section>

<%- include ('../template/footer') %>

<script src="/js/home.js"></script>