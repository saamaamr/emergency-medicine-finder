<%- include("../template/lheader") -%>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <% if (typeof error !== 'undefined' && error && Object.keys(error).length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <% if (error.email) { %><%= error.email %><% } %>
          <% if (error.common) { %><%= error.common %><% } %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <h3 class="contact_heading">Shopkeeper <span>Register</span></h3>
            <p class="text-muted">Register your pharmacy to receive medicine requests</p>
          </div>
          <form action="/shopkeepersignup" method="post" enctype="multipart/form-data" id="shopkeeperSignupForm">
            <div class="row g-3">
              <div class="col-md-6">
                <div class="form-floating mb-3">
                  <input type="text" class="form-control" name="firstName" placeholder="First Name" required>
                  <label><i class="ri-user-line me-1"></i>First Name</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-floating mb-3">
                  <input type="text" class="form-control" name="lastName" placeholder="Last Name" required>
                  <label><i class="ri-user-line me-1"></i>Last Name</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-floating mb-3">
                  <input type="text" class="form-control" name="shopname" placeholder="Shop Name" required>
                  <label><i class="ri-store-2-line me-1"></i>Pharmacy Name</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-floating mb-3">
                  <input type="email" class="form-control" name="email" placeholder="Shop Email" required>
                  <label><i class="ri-mail-line me-1"></i>Shop Email</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-floating mb-3">
                  <input type="tel" class="form-control" name="phone" placeholder="Phone" pattern="01[0-9]{9}" required>
                  <label><i class="ri-phone-line me-1"></i>Phone (01XXXXXXXXX)</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-floating mb-3">
                  <select class="form-select" name="gender" required>
                    <option value="">Select Gender</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                  </select>
                  <label><i class="ri-user-settings-line me-1"></i>Gender</label>
                </div>
              </div>
              <div class="col-md-4">
                <div class="form-floating mb-3">
                  <input type="text" class="form-control" name="house" placeholder="House No" required>
                  <label><i class="ri-home-line me-1"></i>House</label>
                </div>
              </div>
              <div class="col-md-4">
                <div class="form-floating mb-3">
                  <input type="text" class="form-control" name="road" placeholder="Road No" required>
                  <label><i class="ri-road-map-line me-1"></i>Road</label>
                </div>
              </div>
              <div class="col-md-4">
                <div class="form-floating mb-3">
                  <input type="text" class="form-control" name="division" placeholder="Division" required>
                  <label><i class="ri-map-line me-1"></i>Division</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-floating mb-3">
                  <input type="text" class="form-control" name="zila" placeholder="Zila" required>
                  <label><i class="ri-map-pin-line me-1"></i>Zila</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-floating mb-3">
                  <input type="text" class="form-control" name="upazila" placeholder="Upazila" required>
                  <label><i class="ri-map-pin-line me-1"></i>Upazila</label>
                </div>
              </div>
              <div class="col-12">
                <div class="form-floating mb-3">
                  <input type="password" class="form-control" name="pass" placeholder="Password" minlength="6" required>
                  <label><i class="ri-lock-line me-1"></i>Password (min 6 characters)</label>
                </div>
              </div>
            </div>
            <div class="row g-3">
              <div class="col-md-4">
                <div class="mb-3">
                  <label class="form-label"><i class="ri-image-line me-1"></i>Profile Picture</label>
                  <input type="file" class="form-control" name="propic" accept="image/*">
                </div>
              </div>
              <div class="col-md-4">
                <div class="mb-3">
                  <label class="form-label"><i class="ri-id-card-line me-1"></i>NID Page 1</label>
                  <input type="file" class="form-control" name="nid1" accept="image/*">
                </div>
              </div>
              <div class="col-md-4">
                <div class="mb-3">
                  <label class="form-label"><i class="ri-id-card-line me-1"></i>NID Page 2</label>
                  <input type="file" class="form-control" name="nid2" accept="image/*">
                </div>
              </div>
            </div>
            <div class="d-grid gap-3 mt-3">
              <button type="submit" class="btn btn-primary btn-lg rounded-3 w-100">
                <i class="ri-user-add-line me-1"></i>Register & Send OTP
              </button>
              <a href="/shopkeeperlogin" class="btn btn-outline-secondary rounded-3">
                <i class="ri-login-circle-line me-1"></i>Already registered? Login
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include("../template/lfooter") -%>

<script>
  let registerFail = '<%= typeof registerFail !== "undefined" && registerFail ? registerFail : false %>';
  if (registerFail === "true") {
    Swal.fire({
      icon: 'error',
      title: 'Registration Failed',
      text: 'Something went wrong. Please try again.',
    })
  }

  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('verified') === 'true') {
    Swal.fire({
      icon: 'success',
      title: 'Email & Phone Verified!',
      text: 'Your account has been verified. Please login.',
    });
  }
</script>
