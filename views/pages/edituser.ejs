<%- include("../template/header"); -%>
<%- include ('../template/nav') -%>

<section class="layout_padding">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <div class="text-center mb-4">
              <h3 class="contact_heading">Update <span>Profile</span></h3>
              <p class="text-muted small">Update your account information</p>
            </div>
            <form action="/userupdate" method="post" enctype="multipart/form-data">
              <input type="hidden" name="userId" value="<%= user[0].u_id %>">
              
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control <%= typeof error !== 'undefined' && error.firstName ? 'is-invalid' : '' %>" 
                      id="firstName" name="firstName" placeholder="First Name"
                      value="<%= typeof value !== 'undefined' && value.firstName ? value.firstName : user[0].first_name %>" required>
                    <label for="firstName"><i class="ri-user-line me-1"></i>First Name</label>
                    <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.firstName && error.firstName %></div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control <%= typeof error !== 'undefined' && error.lastName ? 'is-invalid' : '' %>" 
                      id="lastName" name="lastName" placeholder="Last Name"
                      value="<%= typeof value !== 'undefined' && value.lastName ? value.lastName : user[0].last_name %>" required>
                    <label for="lastName"><i class="ri-user-line me-1"></i>Last Name</label>
                    <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.lastName && error.lastName %></div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="email" class="form-control" id="email" name="email" 
                      value="<%= user[0].email %>" readonly>
                    <label for="email"><i class="ri-mail-line me-1"></i>Email (read-only)</label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control" id="phone" name="phone" 
                      value="<%= user[0].phone %>" placeholder="Phone">
                    <label for="phone"><i class="ri-phone-line me-1"></i>Phone</label>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-floating mb-3">
                    <select class="form-select" name="gender" id="gender">
                      <option value="Male" <%= user[0].gender === 'Male' ? 'selected' : '' %>>Male</option>
                      <option value="Female" <%= user[0].gender === 'Female' ? 'selected' : '' %>>Female</option>
                      <option value="Other" <%= user[0].gender === 'Other' ? 'selected' : '' %>>Other</option>
                    </select>
                    <label for="gender"><i class="ri-user-settings-line me-1"></i>Gender</label>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control" name="house" placeholder="House" 
                      value="<%= user[0].house %>">
                    <label><i class="ri-home-line me-1"></i>House No</label>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control" name="road" placeholder="Road" 
                      value="<%= user[0].road %>">
                    <label><i class="ri-road-map-line me-1"></i>Road No</label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control" name="division" placeholder="Division" 
                      value="<%= user[0].division %>">
                    <label><i class="ri-map-line me-1"></i>Division</label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control" name="zila" placeholder="Zila" 
                      value="<%= user[0].zila %>">
                    <label><i class="ri-map-pin-line me-1"></i>Zila</label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control" name="upazila" placeholder="Upazila" 
                      value="<%= user[0].upazila %>">
                    <label><i class="ri-map-pin-line me-1"></i>Upazila</label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="password" class="form-control <%= typeof error !== 'undefined' && error.pass ? 'is-invalid' : '' %>" 
                      id="pass" name="pass" placeholder="New Password" 
                      value="<%= typeof value !== 'undefined' && value.pass ? value.pass : '' %>">
                    <label for="pass"><i class="ri-lock-line me-1"></i>New Password (leave blank to keep current)</label>
                    <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.pass && error.pass %></div>
                  </div>
                </div>
                <div class="col-12">
                  <div class="mb-3">
                    <label class="form-label"><i class="ri-image-line me-1"></i>Profile Picture</label>
                    <input type="file" class="form-control" name="propic" accept="image/*">
                    <div class="form-text">Current: <img src="/uploads/<%= user[0].propic %>" height="40" class="rounded"></div>
                  </div>
                </div>
              </div>
              <div class="d-grid gap-3 mt-3">
                <button type="submit" class="btn btn-primary btn-lg">
                  <i class="ri-save-line me-1"></i>Update Profile
                </button>
                <a href="/profile" class="btn btn-outline-secondary">
                  <i class="ri-arrow-left-line me-1"></i>Back to Profile
                </a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../template/footer"); -%>

<script>
  let registerFail = '<%= typeof registerFail !== "undefined" && registerFail ? registerFail : false %>';
  if (registerFail === "true") {
    Swal.fire({
      icon: 'error',
      title: 'Update Failed',
      text: 'Something went wrong. Please try again.',
    })
  }
</script>
