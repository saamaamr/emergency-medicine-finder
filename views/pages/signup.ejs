<%- include("../template/lheader") -%>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card-custom animate-fade-in-up">
        <div class="card-body-custom">
          <div class="text-center mb-4">
            <img src="images/logo.svg" alt="EMF" width="100" class="mb-3">
            <h3 class="mb-2">Create Account</h3>
            <p class="text-muted">Join EMF to find medicines near you</p>
          </div>
          <form action="/signup" method="post" enctype="multipart/form-data">
            <div class="row g-3">
              <div class="col-md-6">
                <div class="mb-3 input-with-icon">
                  <i class="ri-user-line"></i>
                  <input type="text" class="form-control <%= typeof error !== 'undefined' && error.firstName ? 'is-invalid' : '' %>" 
                    id="firstName" name="firstName" placeholder="First Name"
                    value="<%= typeof value !== 'undefined' && value.firstName ? value.firstName : '' %>" required>
                  <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.firstName && error.firstName %></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3 input-with-icon">
                  <i class="ri-user-line"></i>
                  <input type="text" class="form-control <%= typeof error !== 'undefined' && error.lastName ? 'is-invalid' : '' %>" 
                    id="lastName" name="lastName" placeholder="Last Name"
                    value="<%= typeof value !== 'undefined' && value.lastName ? value.lastName : '' %>" required>
                  <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.lastName && error.lastName %></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3 input-with-icon">
                  <i class="ri-mail-line"></i>
                  <input type="email" class="form-control <%= typeof error !== 'undefined' && error.email ? 'is-invalid' : '' %>" 
                    id="floatingInput" name="email" placeholder="Email address"
                    value="<%= typeof value !== 'undefined' && value.email ? value.email : '' %>" required>
                  <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.email && error.email %></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3 input-with-icon">
                  <i class="ri-lock-line"></i>
                  <input type="password" class="form-control <%= typeof error !== 'undefined' && error.pass ? 'is-invalid' : '' %>" 
                    id="floatingPassword" name="pass" placeholder="Password"
                    value="<%= typeof value !== 'undefined' && value.pass ? value.pass : '' %>" required>
                  <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.pass && error.pass %></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3 input-with-icon">
                  <i class="ri-phone-line"></i>
                  <input type="text" class="form-control" name="phone" placeholder="Phone Number" required>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3 input-with-icon">
                  <i class="ri-user-settings-line"></i>
                  <select class="form-select" name="gender" required>
                    <option value="">Select Gender</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
              </div>
              <div class="col-md-4">
                <div class="mb-3 input-with-icon">
                  <i class="ri-home-line"></i>
                  <input type="text" class="form-control" name="house" placeholder="House" required>
                </div>
              </div>
              <div class="col-md-4">
                <div class="mb-3 input-with-icon">
                  <i class="ri-road-map-line"></i>
                  <input type="text" class="form-control" name="road" placeholder="Road" required>
                </div>
              </div>
              <div class="col-md-4">
                <div class="mb-3 input-with-icon">
                  <i class="ri-map-pin-line"></i>
                  <input type="text" class="form-control" name="division" placeholder="Division" required>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3 input-with-icon">
                  <i class="ri-map-line"></i>
                  <input type="text" class="form-control" name="zila" placeholder="Zila" required>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3 input-with-icon">
                  <i class="ri-compass-discover-line"></i>
                  <input type="text" class="form-control" name="upazila" placeholder="Upazila" required>
                </div>
              </div>
              <div class="col-12">
                <div class="mb-2">
                  <label class="form-label">Profile Picture</label>
                  <input type="file" class="form-control" name="propic" accept="image/*">
                </div>
              </div>
            </div>
            <div class="d-grid gap-2 mt-4">
              <button type="submit" class="btn btn-primary btn-lg">
                <i class="ri-user-add-line"></i>Create Account
              </button>
              <a href="/login" class="btn btn-secondary">
                <i class="ri-login-circle-line"></i>Already have an account? Sign In
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include("../template/lfooter"); -%>
<script>
  let registerFail = '<%= typeof registerFail !== "undefined" && registerFail ? registerFail : false %>';
  if (registerFail === "true") {
    Swal.fire({
      icon: 'error',
      title: 'Registration Failed',
      text: 'Something went wrong. Please try again.',
    })
  }
</script>