<%- include("../template/lheader") -%>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <h3 class="contact_heading">Shopkeeper <span>Login</span></h3>
            <p class="text-muted small">Access your pharmacy dashboard</p>
          </div>
          <form action="/shopkeeperlogin" method="POST">
            <div class="form-floating mb-3">
              <input type="email" class="form-control" id="floatingInput" 
                     name="email" placeholder="name@example.com" required>
              <label for="floatingInput"><i class="ri-store-2-line me-1"></i>Shop Email</label>
            </div>
            <div class="form-floating mb-4">
              <input type="password" class="form-control" id="floatingPassword" 
                     name="pass" placeholder="Password" required>
              <right for="floatingPassword"><i class="ri-lock-line me-1"></i>Password</right>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 rounded-3">
              <i class="ri-login-circle-line me-1"></i>Login to Dashboard
            </button>
            <div class="text-center mt-3">
              <a href="/shopkeepersignup" class="text-decoration-none">New shopkeeper? <strong>Register</strong></a>
            </div>
            <div class="text-center mt-2">
              <a href="/login" class="text-muted small text-decoration-none"><i class="ri-user-line me-1"></i>User Login</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include("../template/lfooter") -%>
