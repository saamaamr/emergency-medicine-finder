<%- include("../template/lheader") -%>
<div class="container">
  <div class="row justify-content-center align-items-center min-vh-100">
    <div class="col-md-5 col-lg-4">
      <div class="card-custom animate-fade-in-up">
        <div class="card-body-custom">
          <div class="text-center mb-4">
            <img src="images/logo.svg" alt="EMF" width="100" class="mb-3">
            <h3 class="mb-1">Shopkeeper</h3>
            <p class="text-muted">Access your pharmacy dashboard</p>
          </div>
          <form action="/shopkeeperlogin" method="POST" id="shopkeeperLoginForm">
            <input type="hidden" name="browserKey" id="shopkeeperBrowserKey" value="">
            <div class="mb-3 input-with-icon">
              <i class="ri-store-2-line"></i>
              <input type="email" class="form-control" id="floatingInput"
                     name="email" placeholder="Shop Email" required>
            </div>
            <div class="mb-4 input-with-icon">
              <i class="ri-lock-line"></i>
              <input type="password" class="form-control" id="floatingPassword"
                     name="pass" placeholder="Password" required>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2.5">
              <i class="ri-login-circle-line"></i>Sign In
            </button>
            <div class="text-center mt-4">
              <p class="text-muted mb-2">New pharmacy?</p>
              <a href="/shopkeepersignup" class="btn btn-outline-primary btn-sm">Register Shop</a>
            </div>
            <div class="text-center mt-3">
              <a href="/login" class="text-muted small">
                <i class="ri-user-line me-1"></i>User Login
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include("../template/lfooter") -%>
<script>
  document.getElementById('shopkeeperLoginForm')?.addEventListener('submit', function() {
    const browserKeyInput = document.getElementById('shopkeeperBrowserKey');
    if (browserKeyInput && window.emfBrowserKey) {
      browserKeyInput.value = window.emfBrowserKey;
    }
  });
</script>