<%- include ('../template/header') %>
<%- include ('../template/nav') -%>

<section class="layout_padding">
  <div class="container">
    <div class="heading_container heading_center mb-5">
      <h2>My <span>Bookings</span></h2>
      <p class="text-muted">View your booked services</p>
    </div>

    <% if (userBooking && userBooking.length > 0) { %>
      <div class="row g-4">
        <% userBooking.forEach(booking => { %>
          <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3 mb-3">
                  <div class="bg-primary bg-opacity-10 p-3 rounded-3">
                    <i class="ri-calendar-check-line fs-3 text-primary"></i>
                  </div>
                  <div>
                    <h5 class="card-title mb-1"><%= booking.service_name %></h5>
                    <small class="text-muted"><i class="ri-time-line me-1"></i><%= booking.created_at %></small>
                  </div>
                </div>
                <span class="badge bg-success"><i class="ri-check-line me-1"></i>Confirmed</span>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-5">
        <i class="ri-calendar-line fs-1 text-muted"></i>
        <p class="mt-3 text-muted">You have no bookings yet.</p>
        <a href="/home" class="btn btn-primary mt-2">Browse Services</a>
      </div>
    <% } %>
  </div>
</section>

<%- include("../template/footer"); -%>
