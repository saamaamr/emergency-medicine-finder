<%- include("../template/header"); -%>
<%- include ('../template/nav') -%>

<section class="layout_padding">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <div class="text-center mb-4">
              <h3>Medicine <span>Request</span></h3>
              <p class="text-muted">Submit your medicine request with prescription</p>
            </div>
            <form action="/request" method="post" enctype="multipart/form-data">
              <input type="hidden" name="userId" value="<%= user[0].u_id %>">
              <input type="hidden" name="userMail" value="<%= user[0].email %>">
              <input type="hidden" name="mediId" value="<%= mediData[0].id %>">
              <input type="hidden" name="mediName" value="<%= mediData[0].mediname %>">
              <input type="hidden" name="shopMail" value="<%= mediData[0].shop_email %>">

              <div class="row g-3">
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="text" class="form-control" value="<%= mediData[0].mediname %>" readonly>
                    <label><i class="ri-medicine-bottle-line me-1"></i>Medicine Name</label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-floating mb-3">
                    <input type="number" class="form-control" name="quantity" placeholder="Quantity" required>
                    <label><i class="ri-box-3-line me-1"></i>Quantity</label>
                  </div>
                </div>
                <div class="col-12">
                  <div class="mb-3">
                    <label class="form-label"><i class="ri-image-line me-1"></i>Prescription Picture</label>
                    <input type="file" class="form-control" name="ppic" accept="image/*" required>
                  </div>
                </div>
              </div>
              <div class="d-grid gap-3 mt-3">
                <button type="submit" class="btn btn-primary btn-lg rounded-3 w-100">
                  <i class="ri-send-plane-line me-1"></i>Submit Request
                </button>
                <a href="/home" class="btn btn-outline-secondary rounded-3">
                  <i class="ri-arrow-left-line me-1"></i>Back to Home
                </a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../template/footer"); -%>

<script src="/js/home.js"></script>
