<%- include ('../template/aheader') %>

<section class="main">
  <div class="sidebar">
    <ul class="sidebar--items">
      <li><a href="/shopkeeper">
        <span class="icon icon-1"><i class="ri-layout-grid-line"></i></span>
        <span class="sidebar--item">Dashboard</span>
      </a></li>
      <li><a href="/servicereq" id="active--link">
        <span class="icon icon-2"><i class="ri-git-repository-line"></i></span>
        <span class="sidebar--item">Requests</span>
      </a></li>
    </ul>
    <ul class="sidebar--bottom-items">
      <li><a href="/shopkeeperlogout">
        <span class="icon icon-8"><i class="ri-logout-box-r-line"></i></span>
        <span class="sidebar--item">Logout</span>
      </a></li>
    </ul>
  </div>

  <div class="main--content">
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="p-3 border-bottom">
          <h5 class="section--title mb-0"><i class="ri-file-list-3-line me-1"></i>Medicine Requests</h5>
        </div>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>Medicine</th>
                <th>User</th>
                <th>Email</th>
                <th>Qty</th>
                <th>Prescription</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% allMedicine.map(worker=>{ %>
                <tr>
                  <td class="fw-500"><%= worker.medi_name %></td>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <div>
                        <div class="fw-500"><%= worker.first_name %> <%= worker.last_name %></div>
                        <div class="text-muted small"><%= worker.phone %></div>
                      </div>
                    </div>
                  </td>
                  <td class="text-muted small"><%= worker.user_email %></td>
                  <td><span class="badge bg-info"><%= worker.quantity %> pcs</span></td>
                  <td>
                    <img src="uploads/<%=worker.ppic%>" alt="Prescription" style="width:50px; height:50px; object-fit:cover;" class="rounded">
                  </td>
                  <%if(worker.status==0){%>
                    <td><span class="badge bg-warning">Pending</span></td>
                    <td>
                      <a class="btn btn-sm btn-primary" href="/verify-medicine-request/<%=worker.req_id%>">
                        <i class="ri-check-line"></i> Accept
                      </a>
                    </td>
                  <% }else if(worker.status==1){ %>
                    <td><span class="badge bg-success">Approved</span></td>
                    <td>
                      <a class="btn btn-sm btn-warning" href="/hold-medicine-request/<%=worker.req_id%>">
                        <i class="ri-close-line"></i> Reject
                      </a>
                    </td>
                  <% }else{ %>
                    <td><span class="badge bg-danger">On Hold</span></td>
                    <td>
                      <a class="btn btn-sm btn-primary" href="/verify-medicine-request/<%=worker.req_id%>">
                        <i class="ri-refresh-line"></i> Activate
                      </a>
                    </td>
                  <% } %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>
