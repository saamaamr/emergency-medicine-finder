<%- include ('../template/header') %>
<%- include ('../template/nav') -%>

<section class="layout_padding">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <div class="d-flex align-items-center gap-4 mb-4">
              <img src="uploads/<%= userData[0].propic %>" alt="Profile" 
                   class="rounded-circle border border-3 border-primary" 
                   class="profile-image-xs">
              <div>
                <h3 class="mb-1"><%= userData[0].first_name %> <span><%= userData[0].last_name %></span></h3>
                <p class="text-muted mb-0"><i class="ri-mail-line me-1"></i><%= userData[0].email %></p>
                <span class="badge bg-<%= userData[0].status == 1 ? 'success' : 'warning' %> mt-1">
                  <%= userData[0].status == 1 ? 'Active' : 'Pending' %>
                </span>
              </div>
            </div>
            <hr>
            <div class="row g-3">
              <div class="col-md-6">
                <p class="mb-1 text-muted small">Phone</p>
                <p class="fw-semibold"><i class="ri-phone-line me-1 text-primary"></i><%= userData[0].phone %></p>
              </div>
              <div class="col-md-6">
                <p class="mb-1 text-muted small">Gender</p>
                <p class="fw-semibold"><i class="ri-user-line me-1 text-primary"></i><%= userData[0].gender %></p>
              </div>
              <div class="col-12">
                <p class="mb-1 text-muted small">Address</p>
                <p class="fw-semibold">
                  <i class="ri-map-pin-line me-1 text-primary"></i>
                  House: <%= userData[0].house %>, Road: <%= userData[0].road %><br>
                  <%= userData[0].upazila %>, <%= userData[0].zila %>, <%= userData[0].division %>
                </p>
              </div>
            </div>
            <hr>
            <div class="d-flex gap-3 flex-wrap">
              <a href="/userupdate" class="btn btn-primary">
                <i class="ri-edit-line me-1"></i>Edit Profile
              </a>
              <a href="/req" class="btn btn-outline-primary">
                <i class="ri-file-list-3-line me-1"></i>My Requests
              </a>
              <a href="/logout" class="btn btn-outline-danger ms-auto">
                <i class="ri-logout-box-r-line me-1"></i>Logout
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../template/footer"); -%>
