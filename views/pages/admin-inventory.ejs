<%- include ('../template/aheader') %>

<section class="main">
  <div class="sidebar">
    <ul class="sidebar--items">
      <li><a href="/admin">
        <span class="icon icon-1"><i class="ri-layout-grid-line"></i></span>
        <span class="sidebar--item">Dashboard</span>
      </a></li>
      <li><a href="/service">
        <span class="icon icon-2"><i class="ri-git-repository-line"></i></span>
        <span class="sidebar--item">Medicine</span>
      </a></li>
      <li><a href="/admin/inventory" id="active--link">
        <span class="icon icon-3"><i class="ri-store-2-line"></i></span>
        <span class="sidebar--item">Inventory</span>
      </a></li>
      <li><a href="/admin/transfers">
        <span class="icon icon-4"><i class="ri-exchange-line"></i></span>
        <span class="sidebar--item">Transfers</span>
      </a></li>
      <li><a href="/user">
        <span class="icon icon-5"><i class="ri-user-line"></i></span>
        <span class="sidebar--item">User</span>
      </a></li>
      <li><a href="/shopkeeper">
        <span class="icon icon-6"><i class="ri-user-2-line"></i></span>
        <span class="sidebar--item">Shopkeeper</span>
      </a></li>
    </ul>
    <ul class="sidebar--bottom-items">
      <li><a href="/adminlogout">
        <span class="icon icon-8"><i class="ri-logout-box-r-line"></i></span>
        <span class="sidebar--item">Logout</span>
      </a></li>
    </ul>
  </div>

  <div class="main--content">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="section--title mb-0"><i class="ri-store-2-line me-1"></i>All Shop Inventories</h4>
    </div>

    <!-- Filter by Shop -->
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-body p-3">
        <form class="row g-2 align-items-end" method="get" action="/admin/shop-inventory">
          <div class="col-md-4">
            <label class="form-label small">Filter by Shop</label>
            <select class="form-select" name="email">
              <option value="">All Shops</option>
              <% shops.forEach(shop => { %>
                <option value="<%= shop.email %>"><%= shop.shopname %> - <%= shop.division %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100"><i class="ri-filter-3-line"></i> Filter</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Inventory Table -->
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>Shop Name</th>
                <th>Medicine</th>
                <th>Type</th>
                <th>Strength</th>
                <th>Generic</th>
                <th>Stock</th>
                <th>Price</th>
                <th>Contact</th>
              </tr>
            </thead>
            <tbody>
              <% if(inventories.length === 0) { %>
                <tr><td colspan="8" class="text-center py-4 text-muted">No inventory data available</td></tr>
              <% } %>
              <% inventories.forEach(item => { %>
                <tr>
                  <td><strong><%= item.shopname %></strong></td>
                  <td><%= item.mediname %></td>
                  <td><span class="badge bg-light text-dark"><%= item.meditype %></span></td>
                  <td><%= item.medistrength %></td>
                  <td class="text-muted small"><%= item.medigeneric %></td>
                  <td><span class="badge <%= item.stock > 50 ? 'bg-success' : item.stock > 10 ? 'bg-warning' : 'bg-danger' %>"><%= item.stock %></span></td>
                  <td class="fw-bold"><%= item.price %> tk</td>
                  <td><%= item.phone %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Note: Read-only -->
    <div class="alert alert-info mt-3">
      <i class="ri-information-line me-1"></i> This is a read-only view. Admin cannot edit shop inventory directly. To request stock movement, use the <a href="/admin/transfers" class="alert-link">Transfers</a> page.
    </div>
  </div>
</section>

<%- include('../template/alfooter') %>
