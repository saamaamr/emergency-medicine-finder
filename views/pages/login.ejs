<%- include("../template/lheader") -%>
<div class="container">
  <div class="row justify-content-center align-items-center min-vh-100">
    <div class="col-md-5 col-lg-4">
      <div class="card-custom animate-fade-in-up">
        <div class="card-body-custom">
          <div class="text-center mb-4">
            <img src="images/logo.svg" alt="EMF" width="120" class="mb-3">
            <h3 class="mb-1">Welcome Back</h3>
            <p class="text-muted">Sign in to find medicines near you</p>
          </div>
          <form action="/login" method="POST" novalidate>
            <input type="hidden" name="browserKey" id="loginBrowserKey" value="">
            <div class="mb-3 input-with-icon">
              <i class="ri-mail-line"></i>
              <input type="email" class="form-control <%= typeof error !== 'undefined' && error.email ? 'is-invalid' : '' %>"
                id="floatingInput" name="email"
                placeholder="Email address"
                value="<%= typeof value !== 'undefined' && value.email ? value.email : '' %>" required>
              <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.email && error.email %></div>
            </div>
            <div class="mb-4 input-with-icon">
              <i class="ri-lock-line"></i>
              <input type="password" class="form-control <%= typeof error !== 'undefined' && error.pass ? 'is-invalid' : '' %>"
                id="floatingPassword" name="pass"
                placeholder="Password"
                value="<%= typeof value !== 'undefined' && value.pass ? value.pass : '' %>" required>
              <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.pass && error.pass %></div>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2.5" id="lgnBtn">
              <i class="ri-login-circle-line"></i>Sign In
            </button>
            <div class="text-center mt-4">
              <p class="text-muted mb-2">Don't have an account?</p>
              <a href="/signup" class="btn btn-outline-primary btn-sm">Create Account</a>
            </div>
            <div class="text-center mt-3">
              <a href="/shopkeeperlogin" class="text-muted small">
                <i class="ri-store-2-line me-1"></i>Shopkeeper Login
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include("../template/lfooter") -%>
<script>
  let auth = '<%= typeof auth !== "undefined" ? auth : "false" %>';
  let errorMsg = '<%= typeof error !== "undefined" && error ? error : "false" %>';

  if (auth === "true") {
    let msg = 'Authentication failed';
    if (errorMsg && errorMsg !== 'false' && errorMsg !== 'true') {
      msg = errorMsg;
    }
    Swal.fire({
      icon: 'error',
      title: 'Oops...',
      text: msg,
      footer: '<a href="/signup">Don\'t have an account?</a>'
    })
  }

  document.querySelector('form[action="/login"]')?.addEventListener('submit', function(e) {
    const browserKeyInput = document.getElementById('loginBrowserKey');
    if (browserKeyInput && window.emfBrowserKey) {
      browserKeyInput.value = window.emfBrowserKey;
    }
  });
</script>
