<%- include("../template/lheader") -%>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <h3 class="contact_heading">User <span>Login</span></h3>
            <p class="text-muted small">Sign in to find medicines near you</p>
          </div>
          <form action="/login" method="POST" novalidate>
            <div class="form-floating mb-3">
              <input type="email" class="form-control <%= typeof error !== 'undefined' && error.email ? 'is-invalid' : '' %>" 
                id="floatingInput" name="email" 
                placeholder="name@example.com" 
                value="<%= typeof value !== 'undefined' && value.email ? value.email : '' %>" required>
              <label for="floatingInput"><i class="ri-mail-line me-1"></i>Email address</label>
              <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.email && error.email %></div>
            </div>
            <div class="form-floating mb-4">
              <input type="password" class="form-control <%= typeof error !== 'undefined' && error.pass ? 'is-invalid' : '' %>" 
                id="floatingPassword" name="pass" 
                placeholder="Password" 
                value="<%= typeof value !== 'undefined' && value.pass ? value.pass : '' %>" required>
              <label for="floatingPassword"><i class="ri-lock-line me-1"></i>Password</label>
              <div class="invalid-feedback"><%= typeof error !== 'undefined' && error.pass && error.pass %></div>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 rounded-3" id="lgnBtn">
              <i class="ri-login-circle-line me-1"></i>Login
            </button>
            <div class="text-center mt-3">
              <a href="/signup" class="text-decoration-none">Don't have an account? <strong>Register</strong></a>
            </div>
            <div class="text-center mt-2">
              <a href="/shopkeeperlogin" class="text-muted small text-decoration-none"><i class="ri-store-2-line me-1"></i>Shopkeeper Login</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include("../template/lfooter") -%>
<script>
  let auth = '<%= typeof auth !== "undefined" ? auth : "false" %>';
  if (auth === "true") {
    Swal.fire({
      icon: 'error',
      title: 'Oops...',
      text: 'Authentication failed',
      footer: '<a href="/signup">Don\'t have an account?</a>'
    })
  }
</script>
